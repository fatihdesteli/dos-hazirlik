generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// Unite (Matematik, Turkce, Geometri)
model Subject {
  id        String   @id @default(cuid())
  name      String   @unique
  order     Int      @default(0)
  topics    Topic[]
  createdAt DateTime @default(now())
}

// Konu (Faktoriyel, Permutasyon, vb.)
model Topic {
  id         String     @id @default(cuid())
  name       String
  subjectId  String
  subject    Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  order      Int        @default(0)
  subTopics  SubTopic[]
  createdAt  DateTime   @default(now())

  @@unique([subjectId, name])
}

// Alt Konu (Faktoriyelde Toplama, vb.)
model SubTopic {
  id        String     @id @default(cuid())
  name      String
  topicId   String
  topic     Topic      @relation(fields: [topicId], references: [id], onDelete: Cascade)
  order     Int        @default(0)
  questions Question[]
  createdAt DateTime   @default(now())

  @@unique([topicId, name])
}

// Soru
model Question {
  id          String   @id @default(cuid())
  text        String   // Soru metni
  optionA     String
  optionB     String
  optionC     String
  optionD     String
  optionE     String?  // Bazi sorularda 5. sik olmayabilir
  correctAnswer String // "A", "B", "C", "D", "E"
  explanation String   // Yanlis cevap durumunda gosterilecek aciklama
  difficulty  Int      @default(1) // 1=kolay, 2=orta, 3=zor
  subTopicId  String
  subTopic    SubTopic @relation(fields: [subTopicId], references: [id], onDelete: Cascade)
  answers     UserAnswer[]
  repetitions SpacedRepetition[]
  createdAt   DateTime @default(now())
}

// Kullanici Cevaplari
model UserAnswer {
  id          String   @id @default(cuid())
  questionId  String
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  givenAnswer String   // Kullanicinin verdigi cevap
  isCorrect   Boolean
  timeSpent   Int?     // Saniye cinsinden harcanan sure
  quizId      String?
  quiz        Quiz?    @relation(fields: [quizId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
}

// Test / Quiz
model Quiz {
  id          String       @id @default(cuid())
  title       String?
  mode        String       // "topic", "mixed", "adaptive", "spaced"
  totalQuestions Int
  correctCount  Int        @default(0)
  wrongCount    Int        @default(0)
  isCompleted Boolean      @default(false)
  answers     UserAnswer[]
  createdAt   DateTime     @default(now())
  completedAt DateTime?
}

// Aralikli Tekrar (Spaced Repetition)
model SpacedRepetition {
  id          String   @id @default(cuid())
  questionId  String
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  easeFactor  Float    @default(2.5) // SM-2 ease factor
  interval    Int      @default(1)   // Gun cinsinden aralik
  repetitions Int      @default(0)   // Tekrar sayisi
  nextReview  DateTime @default(now()) // Sonraki tekrar tarihi
  updatedAt   DateTime @updatedAt

  @@unique([questionId])
}

// Konu Bazli Istatistik (Cache)
model TopicStats {
  id            String   @id @default(cuid())
  subTopicId    String   @unique
  totalAnswered Int      @default(0)
  correctCount  Int      @default(0)
  wrongCount    Int      @default(0)
  accuracy      Float    @default(0) // Yuzdel basari orani
  lastPracticed DateTime?
  weaknessLevel Int      @default(0) // 0=bilinmiyor, 1=guclu, 2=orta, 3=zayif
  updatedAt     DateTime @updatedAt
}

// Gunluk Aktivite (Streak takibi)
model DailyActivity {
  id            String   @id @default(cuid())
  date          DateTime @unique @db.Date
  questionsAnswered Int  @default(0)
  correctCount  Int      @default(0)
  studyMinutes  Int      @default(0)
  createdAt     DateTime @default(now())
}
